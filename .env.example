# Copy to .env and fill in. Only the two keys marked REQUIRED are needed
# to start (Phase 1); the rest have defaults or belong to later phases.

# --- OpenAI (REQUIRED) ---
OPENAI_API_KEY=
# Defaults: gpt-4o-mini / text-embedding-3-small. Embedding model must match
# between ingestion and query.
OPENAI_CHAT_MODEL=
OPENAI_EMBEDDING_MODEL=

# --- Pinecone (key REQUIRED; index defaults to aws-mlops-docs) ---
PINECONE_API_KEY=
PINECONE_INDEX_NAME=

# --- AWS (defaults to us-east-1) ---
AWS_REGION=

# --- Jira (Phase 4 — optional until then) ---
# 1. Base URL of your Jira Cloud site, e.g. https://your-site.atlassian.net
#    No free site yet? Create one at https://www.atlassian.com/software/jira/free
#    (the free tier is enough for this project).
JIRA_BASE_URL=

# 2. The email address you log into that Jira site with.
JIRA_EMAIL=

# 3. API token (NOT your account password):
#    - Log in at https://id.atlassian.com/manage-profile/security/api-tokens
#    - Click "Create API token", name it (e.g. "aws-mlops-support-agent"), Create.
#    - Copy it immediately — Atlassian only shows it once.
JIRA_API_TOKEN=

# 4. Project key to file tickets under, e.g. "SUP" for a project named
#    "Support". Find it in Jira under Project settings > Details > Key, or
#    from any issue ID in that project (SUP-123 -> key is SUP). If you don't
#    have a project yet: Jira sidebar > Projects > Create project (the
#    "Kanban" or "Scrum" template both work fine for this).
JIRA_PROJECT_KEY=

# --- Safety: gates real Jira ticket creation. Defaults to true (no real
# tickets are ever created unless this is explicitly set to false). ---
DRY_RUN=

# --- LangSmith tracing (Phase 5 — optional) ---
# Leave all three empty to run without tracing (nothing is sent anywhere).
# To see each graph run (nodes, edges, retrieval, LLM call) as a trace:
# 1. Free account at https://smith.langchain.com -> Settings -> API Keys.
# 2. Set LANGSMITH_TRACING=true and paste the key below.
# 3. Project name is the bucket traces land in (defaults to "default").
LANGSMITH_TRACING=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
